# ============================================
#   HOSPITAL MANAGEMENT SYSTEM — .gitignore
# ============================================

# ── SENSITIVE FILES — NEVER COMMIT THESE ──
**/application.properties
**/.env
**/.env.local
**/.env.production
**/secrets.properties

# ── Java / Maven ──
target/
*.class
*.jar
*.war
*.ear
*.log
.mvn/
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# ── Node.js / React ──
node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── IDEs ──
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Batch scripts with local paths (optional) ──
START_HMS.bat
STOP_HMS.bat
SETUP_FIRST_TIME.bat
